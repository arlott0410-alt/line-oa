# ===========================================
# LineUnifiedInbox - Environment Variables
# ===========================================
# Copy to .env.local for Next.js frontend
# For Cloudflare Workers: use `wrangler secret put <NAME>`

# --- Line Official Account ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Worker URL (for API calls + webhook URL display in Settings)
# Set this in .env.local and Cloudflare Pages env vars for production
NEXT_PUBLIC_WORKER_URL=https://your-worker.workers.dev

# For Workers (bypass RLS when storing webhook data):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
